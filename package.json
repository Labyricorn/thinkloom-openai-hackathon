    "desktop:build": "vite build --config vite.desktop.config.ts",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tiptap/markdown": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/react": "^3.28.0",
